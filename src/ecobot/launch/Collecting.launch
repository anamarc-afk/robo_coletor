<!-- Collecting launch - ROS Noetic / TurtleBot3 -->
<launch>
  <arg name="model"           default="$(env TURTLEBOT3_MODEL)" doc="model type [burger, waffle, waffle_pi]"/>
  <arg name="yaml_file"       default="$(find ecobot)/data/maps/CollectorSpace.yaml"/>
  <arg name="gazebo_world_file" default="$(find ecobot)/data/world/CollectorSpace.world"/>

  <!-- Map Server -->
  <node name="map_server" pkg="map_server" type="map_server"
        args="$(arg yaml_file)" respawn="false">
    <param name="frame_id" value="map"/>
  </node>

  <!-- Gazebo -->
  <arg name="gui" default="true"/>
  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="use_sim_time" value="true"/>
    <arg name="debug"        value="false"/>
    <arg name="gui"          value="$(arg gui)"/>
    <arg name="world_name"   value="$(arg gazebo_world_file)"/>
  </include>

  <!-- Spawn TurtleBot3 -->
  <param name="robot_description"
    command="$(find xacro)/xacro '$(find turtlebot3_description)/urdf/turtlebot3_$(arg model).urdf.xacro'"/>

  <node pkg="gazebo_ros" type="spawn_model" name="spawn_urdf"
        args="-urdf -model turtlebot3_$(arg model) -x 7.0 -y 6.5 -z 0.0 -param robot_description"/>

  <node pkg="robot_state_publisher" type="robot_state_publisher" name="robot_state_publisher">
    <param name="publish_frequency" type="double" value="50.0"/>
  </node>

  <!-- AMCL -->
  <include file="$(find turtlebot3_navigation)/launch/amcl.launch"/>

  <!-- move_base with A* plugin -->
  <include file="$(find ecobot)/data/includes/move_base.launch.xml"/>

  <!-- RViz -->
  <node pkg="rviz" type="rviz" name="rviz" output="screen"
        args="-d $(find turtlebot3_navigation)/rviz/turtlebot3_navigation.rviz"/>

  <arg name="record" default="false"/>
  <node pkg="rosbag" type="record" name="record"
        args="-a -O $(find ecobot)/results/recording.bag -x /camera/(.*) --duration=25"
        if="$(arg record)"/>
</launch>
