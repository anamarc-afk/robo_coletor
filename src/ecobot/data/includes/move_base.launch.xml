<!-- move_base with A* plugin - ROS Noetic -->
<launch>
  <arg name="odom_frame_id"   default="odom"/>
  <arg name="base_frame_id"   default="base_footprint"/>
  <arg name="global_frame_id" default="map"/>
  <arg name="odom_topic"      default="odom"/>
  <arg name="laser_topic"     default="scan"/>

  <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen">
    <!-- Use the custom A* global planner -->
    <param name="base_global_planner" value="astar_plugin/AStarPlanner"/>
    <param name="base_local_planner"  value="dwa_local_planner/DWAPlannerROS"/>

    <rosparam file="$(find ecobot)/data/param/move_base_params.yaml"          command="load"/>
    <rosparam file="$(find ecobot)/data/param/costmap_common_params.yaml"     command="load" ns="global_costmap"/>
    <rosparam file="$(find ecobot)/data/param/costmap_common_params.yaml"     command="load" ns="local_costmap"/>
    <rosparam file="$(find ecobot)/data/param/local_costmap_params.yaml"      command="load"/>
    <rosparam file="$(find ecobot)/data/param/global_costmap_params.yaml"     command="load"/>
    <rosparam file="$(find ecobot)/data/param/base_local_planner_params.yaml" command="load"/>

    <param name="global_costmap/global_frame"       value="$(arg global_frame_id)"/>
    <param name="global_costmap/robot_base_frame"   value="$(arg base_frame_id)"/>
    <param name="local_costmap/global_frame"        value="$(arg odom_frame_id)"/>
    <param name="local_costmap/robot_base_frame"    value="$(arg base_frame_id)"/>
    <param name="DWAPlannerROS/global_frame_id"     value="$(arg odom_frame_id)"/>

    <remap from="odom" to="$(arg odom_topic)"/>
    <remap from="scan" to="$(arg laser_topic)"/>
    <!-- In Noetic/TurtleBot3 cmd_vel is published directly -->
    <remap from="cmd_vel" to="cmd_vel"/>
  </node>
</launch>
